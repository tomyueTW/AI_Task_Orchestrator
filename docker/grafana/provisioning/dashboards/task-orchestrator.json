{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Task Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(task_completed_total[1m])",
          "legendFormat": "Completed/s",
          "refId": "A"
        },
        {
          "expr": "rate(task_failed_total[1m])",
          "legendFormat": "Failed/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      }
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "task_queue_depth{state=\"waiting\"}",
          "legendFormat": "Waiting",
          "refId": "A"
        },
        {
          "expr": "task_queue_depth{state=\"active\"}",
          "legendFormat": "Active",
          "refId": "B"
        },
        {
          "expr": "task_queue_depth{state=\"dlq\"}",
          "legendFormat": "DLQ",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "P99 Processing Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(task_processing_duration_seconds_bucket{status=\"completed\"}[5m]))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(task_processing_duration_seconds_bucket{status=\"completed\"}[5m]))",
          "legendFormat": "P50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(task_failed_total[5m]) / (rate(task_completed_total[5m]) + rate(task_failed_total[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] } },
        "overrides": []
      }
    },
    {
      "title": "DLQ Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "task_dlq_total",
          "legendFormat": "Total DLQ",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ai-task-orchestrator"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "AI Task Orchestrator",
  "uid": "ai-task-orchestrator"
}
