{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@app/queue": ["libs/queue/src"],
      "@app/queue/*": ["libs/queue/src/*"],
      "@app/idempotency": ["libs/idempotency/src"],
      "@app/idempotency/*": ["libs/idempotency/src/*"],
      "@app/observability": ["libs/observability/src"],
      "@app/observability/*": ["libs/observability/src/*"],
      "@app/cost-governor": ["libs/cost-governor/src"],
      "@app/cost-governor/*": ["libs/cost-governor/src/*"],
      "@app/router": ["libs/router/src"],
      "@app/router/*": ["libs/router/src/*"]
    }
  }
}
